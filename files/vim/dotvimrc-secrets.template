" ~/.vimrc-secrets template
"
" hm-vim-secrets が secrets/vim.yaml (sops) を復号し、placeholder を
" 埋め込んで ~/.vimrc-secrets を生成する。
" placeholder は @ で囲んだ大文字名 (例: 下記の OPENAI_API_KEY) のみ書くこと。
" コメント中にも @ で囲んだ大文字名を書くと placeholder として誤検出されるため注意。
" 生成物は dotvimrc から source される (g:openai_api_key 等)。
"
" このファイル自体には平文 secret を書かないこと (placeholder のみ)。
let g:openai_api_key = "@OPENAI_API_KEY@"
